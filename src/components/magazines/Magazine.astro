---
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import Gallery from "./Gallery.astro";

import stickers from "@/assets/magazines/magazine/stickers.png";

import Sep from "@/assets/sep.svg";

const entry = await getEntry("magazines", "magazine");
if (!entry) {
  throw new Error("Hack Club magazine entry not found");
}

const { logo, pages } = entry.data;
---

<div class="bg-magazine relative text-white">
  <Sep class="text-magazine absolute inset-x-0 -top-2.5 h-auto w-full" />

  <div class="p-12 sm:p-16">
    <div class="flex justify-between text-xl text-current/75">
      <p>#1</p>
      <p>&mdash; magazine</p>
    </div>
    <p class="mt-4 text-3xl leading-snug text-pretty">
      The Hack Club showcase. 158 awesome projects made by 100 Hack Clubbers in
      2025, all in one magazine. Each teenager designed their own page to show
      off their project to you.
    </p>
    <a
      href="#"
      class="font-jua corner-squircle text-magazine mt-6 flex h-12 w-fit items-center rounded-3xl bg-white px-5 text-xl transition hover:scale-105 hover:bg-neutral-200 active:scale-100"
    >
      view hack club magazine
      <span
        class="bg-magazine ml-2 grid size-5 place-items-center rounded-full text-sm text-white uppercase"
        >&gt;</span
      >
    </a>
  </div>
  <div class="relative overflow-x-clip">
    <Gallery pages={pages} />
    <Image
      src={logo}
      alt=""
      role="presentation"
      class="absolute top-1/2 left-1/2 h-45 w-auto -translate-x-1/2 -translate-y-1/2 rotate-2 shadow-xl"
    />
  </div>
  <div class="mt-4 overflow-clip">
    <Image
      src={stickers}
      alt=""
      role="presentation"
      class="h-auto w-full drop-shadow-lg"
    />
  </div>
</div>
